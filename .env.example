DB_USERNAME=root
DB_PASSWORD=password
JWT_SECRET=your-jwt-secret-here

# AI provider: set spring.ai.model.chat=openai (default), google-genai, or huggingface
OPENAI_API_KEY=your-openai-api-key
# Only needed when spring.ai.model.chat=google-genai
GEMINI_API_KEY=your-gemini-api-key
# Only needed when spring.ai.model.chat=huggingface (requires deployed Inference Endpoint)
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_ENDPOINT_URL=your-inference-endpoint-url

SEED_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
